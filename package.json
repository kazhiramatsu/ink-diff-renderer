{
  "name": "ink-diff-renderer",
  "version": "1.0.0",
  "description": "Flicker-free terminal rendering with diff-based updates for React Ink",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.examples.json",
    "prepublishOnly": "npm run clean && npm run build",
    "example:basic": "ts-node examples/basic.ts",
    "example:streaming": "ts-node examples/streaming.ts",
    "example:ink": "ts-node examples/with-ink.tsx",
    "example:chat": "ts-node examples/claude-chat.tsx",
    "example:chat-terminal": "ts-node examples/claude-chat-terminal.ts",
    "example:chat-advanced": "ts-node examples/claude-chat-advanced.ts",
    "example:claude-code": "ts-node examples/claude-code-scrollback.ts",
    "example:claude-code-alt": "ts-node examples/claude-code.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "terminal",
    "tui",
    "ink",
    "react",
    "cli",
    "diff",
    "rendering",
    "flicker-free"
  ],
  "author": "Kazutake Hiramatsu <kazutakehiramatsu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazhiramatsu/ink-diff-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/kazhiramatsu/ink-diff-renderer/issues"
  },
  "homepage": "https://github.com/kazhiramatsu/ink-diff-renderer#readme",
  "dependencies": {
    "grapheme-splitter": "^1.0.4",
    "string-width": "^4.2.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/node": "^20.10.0",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0",
    "@types/react": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
